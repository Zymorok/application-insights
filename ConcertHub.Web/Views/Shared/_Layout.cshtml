<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ConcertHub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="app-nav navbar navbar-expand-sm navbar-dark">
            <div class="container-xl">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">ConcertHub</a>
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Відкрити меню">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-sm-center gap-sm-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Оплата</a>
                        </li>
                        <li class="nav-item nav-pill">Enterprise security</li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xl app-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-xl">
            ConcertHub.Web · Azure Key Vault · Application Insights
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
