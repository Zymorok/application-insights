@model PaymentResultViewModel

@{
    ViewData["Title"] = "Оплата успішна";
}

<section class="success-shell">
    <div class="success-mark">✓</div>
    <span class="eyebrow">Secure payment complete</span>
    <h1>Оплата пройшла успішно</h1>
    <p>Транзакція підтверджена після перевірки секретного токена з конфігурації.</p>

    <dl class="receipt">
        <div>
            <dt>Order ID</dt>
            <dd>@Model.OrderId</dd>
        </div>
        <div>
            <dt>Концерт</dt>
            <dd>@Model.ConcertName</dd>
        </div>
        <div>
            <dt>Квитки</dt>
            <dd>@Model.TicketType × @Model.Quantity</dd>
        </div>
        <div>
            <dt>Сума</dt>
            <dd>@Model.Total.ToString("0.00") EUR</dd>
        </div>
    </dl>

    <a asp-action="Index" class="return-link">Нова оплата</a>
</section>
